{
  "name": "localpilot-ai-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "python3 -m backend.app.server --port 8787 --db .localpilot-dev/backend.sqlite",
    "dev:web": "vite --host 127.0.0.1",
    "dev:full": "node scripts/dev-full.mjs",
    "build": "vite build --outDir dist/client --emptyOutDir true && node scripts/prepare-sites-dist.mjs",
    "package:sites": "npm run build && node scripts/package-sites.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "python3 -m unittest discover backend/tests -v && npm run test:approval && npm run test:fake-publish && npm run test:retry-redaction && npm run test:debug && npm run test:storage-boundary && npm run build",
    "test:approval": "python3 -m unittest backend.tests.test_publish_approval -v && node scripts/smoke-approve-snapshot.mjs",
    "test:fake-publish": "python3 -m unittest backend.tests.test_fake_publish_lifecycle -v && node scripts/smoke-fake-publish.mjs",
    "test:debug": "python3 -m unittest backend.tests.test_debug_redaction -v && node scripts/smoke-debug-route.mjs",
    "test:retry-redaction": "python3 -m unittest backend.tests.test_retry_redaction_idempotency -v && node scripts/smoke-retry-redaction.mjs",
    "test:token-boundary": "python3 -m unittest backend.tests.test_token_boundary -v",
    "test:storage-boundary": "node scripts/smoke-no-publish-localstorage.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.10.1"
  },
  "devDependencies": {}
}
